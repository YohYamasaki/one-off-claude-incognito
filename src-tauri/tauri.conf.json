{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "One-off Claude Incognito",
  "version": "0.1.0",
  "identifier": "dev.yamasaki.one-off-claude-incognito",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "macOSPrivateApi": true,
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "category": "Productivity",
    "shortDescription": "Incognito Claude chat overlay",
    "longDescription": "A lightweight macOS overlay that summons an incognito Claude chat window from a global keyboard shortcut. Each window holds an independent ephemeral conversation; nothing is persisted to disk.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "11.0"
    }
  }
}
